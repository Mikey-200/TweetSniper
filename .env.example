# ══════════════════════════════════════════════════════════════════════
# TweetSniper — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to git!
# ══════════════════════════════════════════════════════════════════════

# ─── WALLET / BLOCKCHAIN ──────────────────────────────────────────────

# Your Polymarket private key (exported from polymarket.com → Settings → Export Key)
# For email/Magic.link signups: export from the Polymarket interface
# This is a standard Ethereum hex private key starting with 0x
POLYGON_PRIVATE_KEY=0xyour_private_key_here

# Your Polymarket PROXY wallet address (NOT your MetaMask/EOA address)
# Find it at: polymarket.com → click Deposit → copy the "Deposit to" address
# It looks like a normal Ethereum address: 0x...
PROXY_WALLET_ADDRESS=0xyour_proxy_wallet_address_here

# Alchemy Polygon Mainnet RPC URL (for on-chain USDC deposits)
# Get a free key at: https://dashboard.alchemy.com
# URL format: https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_key_here

# ─── TELEGRAM ─────────────────────────────────────────────────────────

# Bot token from @BotFather on Telegram
# Create a bot: message @BotFather → /newbot → follow steps
TG_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal Telegram chat ID (numeric)
# Find it: message @userinfobot on Telegram → it shows your ID
TG_CHAT_ID=123456789

# ─── SAFETY ───────────────────────────────────────────────────────────

# Set to true to disable real order placement (logs [DRY RUN] instead)
# Use this to test the bot without risking funds
DRY_RUN=false

# ─── TIMING ───────────────────────────────────────────────────────────

# How often to poll for NEW markets (seconds) — default 5
MARKET_POLL_SECS=5

# Backup take-profit poll interval (seconds) — default 300 (5min)
TP_BACKUP_POLL_SECS=300

# Time before alerting on unfilled order (seconds) — default 120 (2min)
FILL_ALERT_SECS=120

# Time before auto-cancelling stale order (seconds) — default 1200 (20min)
STALE_CANCEL_SECS=1200

# Maximum age of a "new" market to scan (minutes) — default 60
MARKET_AGE_MINUTES=60

# UTC hour to send daily P&L summary (0-23) — default 20 (8pm UTC)
DAILY_SUMMARY_UTC_HOUR=20

# ─── ONGOING MARKET SCANNING ─────────────────────────────────────────

# Enable scanning of ongoing (already-running) Elon markets
SCAN_ONGOING_MARKETS=true

# How often to rescan ongoing markets (seconds) — default 600 (10min)
ONGOING_RESCAN_SECS=600

# Stricter price cap for ongoing markets (price discovery has occurred)
MAX_BUY_PRICE_ONGOING=0.20

# ─── ORDER PARAMETERS ────────────────────────────────────────────────

# USD amount to spend per bucket — default $1.00 (start small!)
ORDER_SIZE_USD=1.0

# Skip bucket if best ask > this price (for new markets) — default $0.30
# New markets have wide buckets and cheap prices; skip if overpriced
MAX_BUY_PRICE=0.30

# Skip bucket if bid-ask spread > this — default $0.25
# Large spreads indicate illiquid buckets — avoid them
MAX_SPREAD=0.25

# Number of retries for empty orderbook (x5 seconds) — default 6 = 30s
EMPTY_BOOK_RETRIES=6

# Fallback GTC limit price if orderbook is still empty after retries
FALLBACK_GTC_PRICE=0.25

# Maximum number of buckets to buy per market — default 4
BUCKETS_TO_BUY=4

# How aggressively to skip buckets below projection
# 1.0 = skip if projected > ceiling + 1x width
# 1.5 = skip if projected > ceiling + 1.5x width (default, more lenient)
SKIP_MARGIN_MULTIPLIER=1.5

# ─── TAKE-PROFIT MULTIPLIERS ─────────────────────────────────────────
# TP fires when midpoint price reaches: buy_price × TP_SLOT_N
# Default 2.0 = 2x (100% return) for all slots
# You can set different multipliers per bucket slot

TP_SLOT_0=2.0
TP_SLOT_1=2.0
TP_SLOT_2=2.0
TP_SLOT_3=2.0

# ─── KEYWORD FILTER ──────────────────────────────────────────────────
# Primary keyword to match in market question (case-insensitive)
# Default "elon" — change to "tweets" if no markets are found
ELON_KEYWORD=elon
